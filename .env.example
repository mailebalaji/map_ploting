# OLA MAPS CONFIGURATION
# Get these from your Ola Maps dashboard: https://dashboard.olamaps.io

# API Key (for map initialization - frontend will request this securely)
OLA_API_KEY=your_api_key_here

# Project ID
OLA_PROJECT_ID=your_project_id_here

# OAuth credentials (for backend API calls)
OLA_CLIENT_ID=your_client_id_here
OLA_CLIENT_SECRET=your_client_secret_here

# Server Port (Vercel will override this automatically)
PORT=3000

# SECURITY NOTES:
# 1. Never commit .env file to Git
# 2. Set these variables in Vercel dashboard under: Settings → Environment Variables
# 3. In Ola Maps dashboard, restrict API key to only your Vercel domain
# 4. Consider using separate keys for frontend (map) and backend (OAuth)
